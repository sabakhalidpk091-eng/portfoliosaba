# SQL Server connection string
# Change SERVER, DATABASE, and credentials as needed
DATABASE_URL=mssql+pyodbc:///?odbc_connect=DRIVER={ODBC Driver 17 for SQL Server};SERVER=localhost;DATABASE=portfolio;Trusted_Connection=yes

# Or with username/password:
# DATABASE_URL=mssql+pyodbc://sa:YourPassword@localhost/portfolio?driver=ODBC+Driver+17+for+SQL+Server

CORS_ORIGINS=http://localhost:5173
